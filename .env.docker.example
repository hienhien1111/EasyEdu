# ─────────────────────────────────────────────────────────────────
# EasyEdu — Docker Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=easyedu
POSTGRES_PASSWORD=easyedu_secret
POSTGRES_DB=easyedu
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=

# ── App Ports ──────────────────────────────────────────────────
API_PORT=3001
WEB_PORT=3000

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))")
JWT_SECRET=change-me-to-a-48-byte-random-base64-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-48-byte-random-base64-string
JWT_REFRESH_EXPIRES_IN=30d

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── File Storage (AWS S3 / Cloudflare R2) ──────────────────────
S3_BUCKET=easyedu-files
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ── Payment (PayOS) ────────────────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_WEBHOOK_URL=

# ── OTP ────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
