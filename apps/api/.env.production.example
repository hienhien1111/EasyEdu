# ─────────────────────────────────────────────────────────────
# EasyEdu API — Production Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=https://app.easyedu.study
API_URL=https://api.easyedu.study

# ── Cookie ─────────────────────────────────────────────────────
# Required for cross-subdomain cookie sharing (app ↔ api)
COOKIE_DOMAIN=.easyedu.study

# ── Database (AWS RDS) ─────────────────────────────────────────
# connection_limit=5 recommended for db.t4g.micro
DATABASE_URL=postgresql://USER:PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/easyedu?schema=public&connection_limit=5

# ── Redis (container on same EC2) ──────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace_with_48_byte_random_base64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_48_byte_random_base64
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_your_production_key
EMAIL_FROM=noreply@easyedu.study

# ── OTP ────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Payment (PayOS) ───────────────────────────────────────────
PAYOS_CLIENT_ID=your_production_client_id
PAYOS_API_KEY=your_production_api_key
PAYOS_CHECKSUM_KEY=your_production_checksum_key
PAYOS_WEBHOOK_URL=https://api.easyedu.study/api/payments/webhook

# ── File Storage (Cloudflare R2 — S3-compatible) ──────────────
S3_REGION=auto
S3_BUCKET=easyedu-production
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key
S3_SECRET_ACCESS_KEY=your_r2_secret_key

# ── Optional: Sentry ──────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
