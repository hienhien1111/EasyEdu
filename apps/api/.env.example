# ─────────────────────────────────────────────────────────────
# EasyEdu API — Environment Variables Example
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/easyedu?schema=public"

# JWT — generate strong secrets: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="change-me-to-a-48-byte-random-base64-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-another-48-byte-random-base64-string"
JWT_REFRESH_EXPIRES_IN="30d"

# Redis (required for BullMQ jobs + token blacklist)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# App
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# Email — Resend (https://resend.com)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="noreply@yourdomain.com"

# OTP
OTP_EXPIRY_MINUTES=10

# File Storage — AWS S3 or Cloudflare R2 (optional)
S3_BUCKET="easyedu-files"
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""

# Payment — PayOS (https://payos.vn) — leave empty to use mock
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""
PAYOS_WEBHOOK_URL="https://yourdomain.com/api/payments/webhook"
