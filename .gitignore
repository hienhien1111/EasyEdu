# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
.next/
build/
out/

# Environment — NEVER commit .env files with real secrets
.env
.env.local
.env.*.local
# Docker root env (copy from .env.docker.example)
# .env.docker.example is intentionally tracked

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# Turbo
.turbo/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Prisma
apps/api/prisma/*.db
apps/api/prisma/*.db-journal

# Generated files
apps/api/src/generated/

# Uploads (runtime files — use S3/R2 in production)
apps/api/uploads/

# Next.js build info
apps/web/tsconfig.tsbuildinfo

# Antigravity / AI tools
.antigravityignore

# Personal deployment planning docs
easyedu-aws-deployment-plan.md

# Production env (real secrets — use .env.production.example as template)
*.env.production
apps/api/.env.production
apps/web/.env.production
# But DO track the example templates
!*.env.production.example
